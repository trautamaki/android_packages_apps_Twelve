<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="?attr/materialCardViewFilledStyle"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHighest"
    app:cardCornerRadius="8dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        tools:ignore="RtlSymmetry">

        <ImageView
            android:id="@+id/outputDeviceImageView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:contentDescription="@string/audio_output"
            android:paddingHorizontal="4dp"
            android:paddingVertical="6dp"
            android:src="@drawable/ic_headphones"
            app:tint="?attr/colorOnSurface" />

        <ImageView
            android:id="@+id/hiResImageView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:contentDescription="@string/hi_res"
            android:paddingHorizontal="4dp"
            android:paddingVertical="6dp"
            android:src="@drawable/ic_high_res"
            app:tint="?attr/colorOnSurface" />

        <ImageView
            android:id="@+id/potentialIssuesImageView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:contentDescription="@string/audio_potential_issues"
            android:paddingHorizontal="4dp"
            android:paddingVertical="6dp"
            android:src="@drawable/ic_error"
            app:tint="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/fileTypeTextView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="@string/audio_file_type_unknown_short"
            android:textAlignment="gravity"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurface"
            tools:text="FLAC" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
